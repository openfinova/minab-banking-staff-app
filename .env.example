# Server-only (BFF) — do not prefix with NEXT_PUBLIC_
APP_PUBLIC_URL=http://localhost:3000
API_BASE_URL=http://localhost:8080
OIDC_AUTHORITY=http://localhost:8080
# Docker Compose: OIDC_TOKEN_AUTHORITY=http://banking-app:8080
OIDC_CLIENT_ID=staff-portal
OIDC_CLIENT_SECRET=staff-portal-secret
OIDC_REDIRECT_URI=http://localhost:3000/api/auth/callback
OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:3000/login
OIDC_SCOPES=openid profile email banking.staff
SESSION_SECRET=local-dev-session-secret-change-me-32chars
# false when APP_PUBLIC_URL is http:// (Docker local); true behind HTTPS in production
# SESSION_COOKIE_SECURE=false
SESSION_IDLE_MS=600000
SESSION_ABSOLUTE_MS=28800000

# Client idle warning UI (browser)
NEXT_PUBLIC_IDLE_TIMEOUT_MS=900000
NEXT_PUBLIC_IDLE_WARNING_MS=120000
